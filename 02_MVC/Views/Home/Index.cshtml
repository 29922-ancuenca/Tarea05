@{
    ViewBag.Title = "Home Page";
}

<main class="container">
    <section class="row">
        <div class="col-md-12">
            <h1 id="title">Taller Roles</h1>
            <h2 class="text-dark text-center">Indicaciones</h2>
            <ul style="margin-top:25px; font-size:18px; line-height:1.8;">
                <li>Copiar el proyecto MOLDE_MVC para permitir registro de usuarios.</li>
                <li>Cambiar el nombre del proyecto a Roles_MVC.</li>
                <li>Ejecutar el script UnificadaBD con las tablas EntityBD y PacienteDB_Foto.</li>
                <li>Configurar la cadena de conexión para usar una sola base de datos.</li>
                <li>Crear los roles: Administrador, Paciente y Medico.</li>
                <li>Generar el modelo .edmx incluyendo todas las tablas de la BD.</li>
                <li>Generar el CRUD de la tabla PACIENTES con scaffolding.</li>
                <li>Asignar roles a usuarios (PEPITO, DR. MANOTAS, PLUTARCO).</li>
                <li>Implementar la vista VerRoles para mostrar el rol del usuario autenticado.</li>
                <li>Permitir editar pacientes solo si el usuario está autenticado.</li>
                <li>Aplicar autorización global y específica en los controladores.</li>
            </ul>
            <hr />
        </div>
    </section>

    <div class="row text-center">

        <!-- Columna Izquierda: Integrantes -->
        <section class="col-md-4">
            <div class="p-4 border rounded" style="background-color:white; min-height:350px;">
                <h2 class="text-secondary">Integrantes</h2>
                <div style="margin-top:40px;">
                    <p style="font-size:32px; margin-bottom:10px;">Alisson Cuenca</p>
                    <small class="text-muted">Desarrollo y diseño del proyecto</small>
                </div>
            </div>
        </section>

        <!-- Columna Derecha: Foto Personal -->
        <section class="col-md-4">
            <div class="p-4 border rounded text-center" style="background-color:#f8f9fa; min-height:350px;">
                <img src="~/Foto/yo.png"
                     alt="Foto"
                     class="img-circle img-thumbnail"
                     style="width:170px; height:170px; object-fit:cover; margin-bottom:20px;" />

                <h2>Desarrolladora</h2>
                <p class="text-muted" style="font-size:18px;">
                    Tecnología .NET Framework, ASP.NET MVC y Entity Framework.
                </p>
            </div>
        </section>


    </div>
</main>