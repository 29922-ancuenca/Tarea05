@model _02_MVC.Models.RolePermissionsViewModel

@{
    ViewBag.Title = "Gestión de Permisos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="text-center mb-3">
        <h1><strong>Gestión de Permisos</strong></h1>
        <p class="text-muted">Configura los accesos del sistema clínico</p>
    </div>

    @if (TempData["PermisosGuardados"] != null)
    {
        <div class="alert alert-success">@TempData["PermisosGuardados"]</div>
    }

    <div class="card shadow-sm p-3">
        <div class="mb-3">
            <h4>Rol: <span class="text-primary">@Model.RolNombre</span></h4>
        </div>

        @using (Html.BeginForm("GuardarPermisos", "AspNetUserClaims", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.RolId)

            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th style="width:25%">Módulo</th>
                        <th class="text-center">Ver</th>
                        <th class="text-center">Crear</th>
                        <th class="text-center">Actualizar</th>
                        <th class="text-center">Eliminar</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Pacientes</strong></td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Pacientes_Read)</td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Pacientes_Create)</td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Pacientes_Update)</td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Pacientes_Delete)</td>
                    </tr>
                    <tr>
                        <td><strong>Médicos</strong></td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Medicos_Read)</td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Medicos_Create)</td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Medicos_Update)</td>
                        <td class="text-center">@Html.CheckBoxFor(m => m.Medicos_Delete)</td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex justify-content-between">
                <a class="btn btn-secondary" href="@Url.Action("Index")">Volver</a>
                <button type="submit" class="btn btn-success">Guardar Cambios</button>
            </div>
        }
    </div>
</div>
