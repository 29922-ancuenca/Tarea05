@model IEnumerable<_02_MVC.Models.AspNetRoles>

@{
    ViewBag.Title = "Gestión de Permisos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h1><strong>Gestión de Permisos</strong></h1>
        <p class="text-muted">Administra los accesos del sistema clínico para cada tipo de usuario</p>
    </div>

    <div class="card shadow-sm p-3">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Módulo</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rol in Model)
                {
                    <tr>
                        <td><strong>@rol.Name</strong></td>
                        <td class="text-end">
                            @Html.ActionLink("Gestionar Permisos", "GestionarPermisos", new { rolId = rol.Id }, new { @class = "btn btn-outline-primary" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
